# Ignore all files and directories by default
/*

# Allow the specific project directories
!/backend/
!/frontend_android/
!/frontend_web/
!/.gitignore
!/README.md

# --- Protections and Exclusions ---

# Specifically requested by user
frontend_web/package.json

# Local runtime history and test outputs
*.txt
!README.md
!requirements.txt
!**/requirements.txt
*.log
test_output*
.pytest_cache/

# Never allow keys or identity files anywhere
**/keys/
**/*.pem
**/*.key
**/*.pub

# Ignore local database and memory files
**/*.sqlite
**/*.sqlite-journal
resident_memory.json
agent_config.json

# Ignore temporary and build artifacts
**/__pycache__/
**/*.py[cod]
**/node_modules/
**/dist/
**/build/
**/.gradle/
**/bin/
**/obj/
**/.vs/
**/.idea/
**/.vscode/
.tmp_extraction*/

# Environment files
.env
**/.env.*
venv/
.venv/

# Workspace files
*.code-workspace

# System files
.DS_Store
Thumbs.db
