# Ignore all files and directories by default
/*

# Allow the specific project directories
!/backend/
!/frontend_android/
!/frontend_web/
!/.gitignore
!/README.md
!/tests/
# Exclude agent-specific and sync tools
.antigravity/
sync_all_robust.ps1

# --- Protections and Exclusions ---

# Local runtime history and test outputs
*.txt
!README.md
!requirements.txt
!**/requirements.txt
*.log
test_output*
.pytest_cache/

# Never allow keys or identity files anywhere
**/keys/
**/*.pem
**/*.key
**/*.pub
**/*.crt

# Ignore local database and memory files
**/*.sqlite
**/*.sqlite-journal
resident_memory.json
agent_config.json
governance_store.json

# Ignore temporary and build artifacts
**/__pycache__/
**/*.py[cod]
**/node_modules/
**/dist/
**/build/
**/.gradle/
**/bin/
**/obj/
**/.vs/
**/.idea/
**/.vscode/
.tmp_extraction*/

# Environment files
.env
**/.env.*
venv/
.venv/

# Workspace files
*.code-workspace

# System files
.DS_Store
/backend/data/
/backend/memory/
# Ignore memory backups
/backend/resident_memory_backup_*.json

