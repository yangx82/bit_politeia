# Ignore all files and directories by default
/*

# Allow the specific project directories
!/backend/
!/frontend_android/
!/frontend_web/
!/.gitignore
!/README.md

# --- Protections inside allowed directories ---

# Never allow keys or identity files anywhere
**/keys/
**/*.pem
**/*.key
**/*.pub

# Ignore local database and memory files
**/*.sqlite
**/*.sqlite-journal
resident_memory.json
simulation_log.txt
agent_config.json

# Ignore temporary and build artifacts
**/__pycache__/
**/*.py[cod]
**/node_modules/
**/dist/
**/build/
**/.gradle/
**/bin/
**/obj/
**/.vs/
**/.idea/
**/.vscode/

# Environment files
.env
**/.env.*
venv/
.venv/

# System files
.DS_Store
Thumbs.db
