# Ignore all files and directories by default
/*

# Allow the specific project directories
!/backend/
!/frontend_android/
!/frontend_web/
!/.gitignore
!/README.md
!/tests/
!/scripts/setup_research_node.py
# Exclude agent-specific and sync tools
.antigravity/
sync_all_robust.ps1

# --- Protections and Exclusions ---

# Local runtime history and test outputs
*.txt
!README.md
!requirements.txt
!**/requirements.txt
*.log
test_output*
.pytest_cache/

# Never allow keys or identity files anywhere
**/keys/
**/*.pem
**/*.key
**/*.pub
**/*.crt

# Ignore local database and memory files
**/*.sqlite
**/*.sqlite-journal
resident_memory.json
agent_config.json
governance_store.json

# Ignore temporary and build artifacts
**/__pycache__/
**/*.py[cod]
**/node_modules/
**/dist/
**/build/
**/.gradle/
**/bin/
**/obj/
**/.vs/
**/.idea/
**/.vscode/
.tmp_extraction*/

# Environment files
.env
**/.env.*
venv/
.venv/

# Workspace files
*.code-workspace

# System files
.DS_Store

# Data and Runtime files (Always Excluded)
**/*.toml
**/data/
**/memory/
**/.chroma/
**/.cache/
**/.sqlite*
**/resident_memory_backup_*.json
**/data/logs/
**/p2p/inbox_*.jsonl

# Self-improvement logs and daily reports (Local only)
**/.learnings/
**/LEARNINGS.md
**/ERRORS.md
**/FEATURE_REQUESTS.md
**/daily_report_*.md
**/daily-*.md